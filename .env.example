# ==========================================
# Mundiales de Fútbol — environment variables
# Copy this file to .env.local and fill in.
# ==========================================

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Public site URL (used for metadata, OG tags, sitemaps)
NEXT_PUBLIC_SITE_URL="https://mundiales-de-futbol.com"

# Optional: API-Football (only used during the 2026 World Cup for live data)
# API_FOOTBALL_KEY=""

# Contact form delivery (Resend — https://resend.com)
# Create a free account, verify a sender domain or use the default onboarding@resend.dev,
# then paste the API key below. Without it, submissions are logged but not delivered.
RESEND_API_KEY=""
CONTACT_TO_EMAIL="daniel.mirond@gmail.com"
CONTACT_FROM_EMAIL="Mundiales de Fútbol <onboarding@resend.dev>"

# ──────────────────────────────────────────────────────────────
# SEO / Search Console / Analytics
# ──────────────────────────────────────────────────────────────

# Google Search Console
# 1. Ir a https://search.google.com/search-console
# 2. Añadir propiedad: prefijo de URL → https://mundiales-de-futbol.com
# 3. Método de verificación: «Etiqueta HTML» → copiar el valor del `content`
#    del meta tag (sin las comillas, sin el name=, solo la cadena)
# 4. Pegar aquí y desplegar. Volver a Search Console y pulsar Verificar.
NEXT_PUBLIC_GSC_VERIFICATION=""

# Bing Webmaster Tools (opcional)
# https://www.bing.com/webmasters → añadir sitio → Etiqueta meta
NEXT_PUBLIC_BING_VERIFICATION=""

# Google Analytics 4 (gated por consent del usuario)
# https://analytics.google.com → Admin → Crear propiedad → ID de medición
# Formato: G-XXXXXXXXXX
# El script solo se carga si el usuario acepta cookies analíticas.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ──────────────────────────────────────────────────────────────
# Research diaria (Google Trends + YouTube) — `npm run research`
# ──────────────────────────────────────────────────────────────
# Necesario para `scripts/research/report.ts`.
# 1. https://console.cloud.google.com/ → crea proyecto
# 2. Habilita "YouTube Data API v3"
# 3. Credentials → API key (recomendado restringirla a YouTube Data API)
# Cuota gratis: 10.000 unidades/día (≈ 95 búsquedas).
YOUTUBE_API_KEY=""

# ──────────────────────────────────────────────────────────────
# Porra Mundial 2026 — Stripe (Pase Premium 2,99€)
# ──────────────────────────────────────────────────────────────
# 1. https://dashboard.stripe.com/register → cuenta
# 2. Activar KYC (DNI + datos fiscales)
# 3. Activar Stripe Tax (Settings → Tax) si vendes en EU
# 4. https://dashboard.stripe.com/apikeys → copiar claves
# Mientras la cuenta está en revisión usa las "test" keys.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret. Crear endpoint en
# https://dashboard.stripe.com/webhooks → Add endpoint
# URL: https://mundiales-de-futbol.com/api/porra/webhook
# Events: checkout.session.completed, charge.refunded
STRIPE_WEBHOOK_SECRET=""
