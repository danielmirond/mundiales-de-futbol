# ==========================================
# Mundiales de Fútbol — environment variables
# Copy this file to .env.local and fill in.
# ==========================================

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Public site URL (used for metadata, OG tags, sitemaps)
NEXT_PUBLIC_SITE_URL="https://mundiales-de-futbol.com"

# Optional: API-Football (only used during the 2026 World Cup for live data)
# API_FOOTBALL_KEY=""

# Optional: Anthropic (used for AI-generated match chronicles)
# ANTHROPIC_API_KEY=""

# Contact form delivery (Resend — https://resend.com)
# Create a free account, verify a sender domain or use the default onboarding@resend.dev,
# then paste the API key below. Without it, submissions are logged but not delivered.
RESEND_API_KEY=""
CONTACT_TO_EMAIL="daniel.mirond@gmail.com"
CONTACT_FROM_EMAIL="Mundiales de Fútbol <onboarding@resend.dev>"
